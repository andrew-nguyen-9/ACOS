<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Phase 13.8 — hardened-runtime entitlements for notarization.

  The PyInstaller one-file sidecar (acos-backend) unpacks and executes its own
  bootloader at runtime; under the hardened runtime that Apple notarization
  requires, the following entitlements are needed or the sidecar is killed on
  launch in a notarized build:
    - allow-jit / allow-unsigned-executable-memory: CPython + the PyInstaller
      bootloader allocate executable memory.
    - allow-dyld-environment-variables + disable-library-validation: the
      bootloader sets DYLD_* and loads its bundled, differently-signed .so/.dylib
      extension modules.

  No App Sandbox: ACOS is distributed as a notarized DMG (direct download), not via
  the Mac App Store, and the sidecar opens local sockets / files the sandbox would
  block. This is the deliberate, documented trade-off (see docs/PACKAGING.md).
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
