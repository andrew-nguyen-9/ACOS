# ── Secrets — NEVER commit ──────────────────────────────
.env
.env.local
.env.*
*.env
!.env.example
!.env.local.example
.static_files/

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.cache/

# ── Node / Next ─────────────────────────────────────────
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ── Tauri sidecar binaries (generated by build_backend.sh) ─
frontend/src-tauri/binaries/acos-backend-*
dist/backend/
build/

# ── Build output — regenerated by cargo/vite; never commit ─
frontend/src-tauri/target/
frontend/dist/
!frontend/dist/.gitkeep

# ── Databases & vector store — runtime data, not source ──
*.db
*.sqlite3
# ChromaDB persistent store (backend + any stray copies)
**/chroma/
# stray runtime DB copy under frontend — should not be versioned
frontend/database/

# ── Test / coverage output ──────────────────────────────
.coverage
coverage.json
.coverage_html/
.pytest_cache/
.benchmarks/
test_output.txt

# ── Misc ────────────────────────────────────────────────
.DS_Store
*.log
