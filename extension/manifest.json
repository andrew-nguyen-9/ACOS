{
  "manifest_version": 3,
  "name": "ACOS Job Capture",
  "version": "0.1.0",
  "description": "Capture a job posting from the current page into ACOS (local-first). Explicit click only — no tracking.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "Capture this job to ACOS",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": { "id": "acos-job-capture@local" }
  }
}
