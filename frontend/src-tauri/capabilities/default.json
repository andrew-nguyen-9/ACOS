{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default capability set for ACOS",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "acos-backend",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "updater:default",
    "process:allow-restart"
  ]
}
